                    "text": "Was using Shifted Mathematical System for cartesian positon, and Blauert / Gerzon for spherical rotational coordinates"
                }
            },
            {
                "box": {
                    "bgcolor": [ 1.0, 0.9372549019607843, 0.0, 1.0 ],
